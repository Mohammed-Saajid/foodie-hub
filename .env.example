PROJECT_NAME="Foodie Hub"
DATABASE_URL="YOUR_DATABASE_URL_HERE"
SECRET_KEY="YourSecretKeyHere"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
RESET_TOKEN_EXPIRE_MINUTES=15
OTP_LENGTH=6
ENVIRONMENT="development"
LOG_LEVEL="INFO"
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
ENABLE_RATE_LIMITING=True


# Email Configuration
MAILTRAP_API_TOKEN="YourMailtrapAPITokenHere"
MAILTRAP_ACCOUNT_ID="YourMailtrapAccountIDHere"
EMAIL_FROM= "noreply@foodiehub.com"
EMAIL_FROM_NAME= "Foodie Hub Support"
FRONTEND_URL="http://localhost:3000"

# Rate Limiting Configuration
REDIS_URL="redis://localhost:6379/0"
RATE_LIMIT=100
RATE_WINDOW=60

# SSE Notification Configuration
NOTIFICATION_CHANNEL_PREFIX="notifications"
SSE_RETRY_MS=15000
SSE_HEARTBEAT_SECONDS=20
SSE_POLL_TIMEOUT_SECONDS=1
SSE_MAX_GROUPS_PER_CONNECTION=5
